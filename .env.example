# ──────────────────────────────────────────────
# 🔑 Agora-X 환경변수 템플릿
# 이 파일을 복사하여 .env.local 을 만들고 실제 값을 입력하세요.
# .env.local 은 git에 커밋되지 않습니다.
# ──────────────────────────────────────────────

# Google OAuth 2.0 Client ID (Google Cloud Console에서 발급)
VITE_GOOGLE_CLIENT_ID=

# Kakao JavaScript Key (Kakao Developers에서 발급)
VITE_KAKAO_JS_KEY=

# Claude API Key (Anthropic Console에서 발급) - 추후 사용
# VITE_CLAUDE_API_KEY=
